#include <iostream>
#include "UserFactory.h"
#include "CourseService.h"
#include "AuthProxy.h"
#include "NotificationObserver.h"
#include "QuizStrategy.h"
#include "CourseDecorator.h"

using namespace std;

int main() {
    cout << "===== SkillNest Backend Design Pattern Test =====\n\n";

    /*
    ====================================================
    DESIGN PATTERN 1: FACTORY PATTERN
    ====================================================
    */
    cout << "Testing Factory Pattern\n";

    User* student = UserFactory::createUser("student", "Nuha", "student@skillnest.com");
    User* teacher = UserFactory::createUser("teacher", "Ibra", "teacher@skillnest.com");
    User* admin = UserFactory::createUser("admin", "Admin", "admin@skillnest.com");

    student->showDashboard();
    teacher->showDashboard();
    admin->showDashboard();


    /*
    ====================================================
    DESIGN PATTERN 2: SINGLETON PATTERN
    ====================================================
    */
    cout << "\nTesting Singleton Pattern\n";

    CourseService* service1 = CourseService::getInstance();
    CourseService* service2 = CourseService::getInstance();

    service1->createCourse("Introduction to C++");

    if (service1 == service2) {
        cout << "Singleton works: Both objects are the same instance.\n";
    } else {
        cout << "Singleton failed: Different instances were created.\n";
    }


    /*
    ====================================================
    DESIGN PATTERN 3: OBSERVER PATTERN
    ====================================================
    */
    cout << "\nTesting Observer Pattern\n";

    CourseNotification courseNotification;

    StudentObserver observer1("Nuha");
    StudentObserver observer2("Shafin");

    courseNotification.addStudent(&observer1);
    courseNotification.addStudent(&observer2);

    courseNotification.notifyStudents("A new lesson has been uploaded in Introduction to C++.");


    /*
    ====================================================
    DESIGN PATTERN 4: STRATEGY PATTERN
    ====================================================
    */
    cout << "\nTesting Strategy Pattern\n";

    MCQQuizStrategy mcqStrategy;
    WrittenQuizStrategy writtenStrategy;
    MixedQuizStrategy mixedStrategy;

    QuizGrader grader(&mcqStrategy);

    cout << "MCQ Quiz Score: " << grader.gradeQuiz(8, 10) << "%\n";

    grader.setStrategy(&writtenStrategy);
    cout << "Written Quiz Score: " << grader.gradeQuiz(8, 10) << "%\n";

    grader.setStrategy(&mixedStrategy);
    cout << "Mixed Quiz Score: " << grader.gradeQuiz(8, 10) << "%\n";


    /*
    ====================================================
    DESIGN PATTERN 5: DECORATOR PATTERN
    ====================================================
    */
    cout << "\nTesting Decorator Pattern\n";

    Course* course = new BasicCourse();

    cout << "Original Course: " << course->getDescription() << endl;
    cout << "Original Price: " << course->getPrice() << " BDT\n";

    course = new CertificateDecorator(course);
    course = new PremiumContentDecorator(course);
    course = new ProgressBadgeDecorator(course);

    cout << "Decorated Course: " << course->getDescription() << endl;
    cout << "Final Price: " << course->getPrice() << " BDT\n";


    /*
    ====================================================
    DESIGN PATTERN 6: PROXY PATTERN
    ====================================================
    */
    cout << "\nTesting Proxy Pattern\n";

    AuthProxy studentProxy(student);
    AuthProxy teacherProxy(teacher);
    AuthProxy adminProxy(admin);

    studentProxy.checkAccess("enroll_course");
    studentProxy.checkAccess("approve_course");

    teacherProxy.checkAccess("create_course");
    teacherProxy.checkAccess("approve_course");

    adminProxy.checkAccess("approve_course");
    adminProxy.checkAccess("create_course");


    /*
    ====================================================
    CLEANUP
    ====================================================
    */
    delete student;
    delete teacher;
    delete admin;

    return 0;
}
